%%=========================================================================
% Section 2: Conversion of selected driving scenario to occupancy map 
% This section converts the selected automated driving toolbox scenario
% into a binary occupancy map that can be used by the A* and RRT* path
% planners. The drivingScenario object is only useful for visualizing roads
% vehicles and obstacles, but path planning algorithms require an occupancy
% maps

% The map is first initialized as fully occupied. Then, the drivable road
% regins are carved out as free spance based on the road centerlines from
% the selected scenarion. After free road is specified. obstacle cars are
% added back as occupied regions. Obstacles are inflated to include vehicle
% clearence, this helps prevent planned paths from passing too close to
% parked vehicles or road edges

% start and goal nodes are also shifted into positive occupancy map
% coordinates sicne some driving scenarios use negative y-values. 

%% Map Parameters

resolution = 5;      % cells per meter

mapLength = mapXLimits(2) - mapXLimits(1);
mapWidth  = mapYLimits(2) - mapYLimits(1);

xOffset = -mapXLimits(1);
yOffset = -mapYLimits(1);

map = binaryOccupancyMap(mapLength, mapWidth, resolution);

%% Fill Entire Map as Occupied

[xAll, yAll] = meshgrid(0:0.1:mapLength, 0:0.1:mapWidth);
allPoints = [xAll(:), yAll(:)];
setOccupancy(map, allPoints, 1);

%% Road Width

roadWidth = 8.0;     % meters

%% Clear Drivable Road Regions

switch scenarioID

    case 1
        % Scenario 1: straight road along x-axis
        clearRoadRectangle(map, ...
            0 + xOffset, ...
            -roadWidth/2 + yOffset, ...
            60 + xOffset, ...
            roadWidth/2 + yOffset);

    case 2
        % Scenario 2: curved road approximation using connected segments
         roadCenters = [
        0    0
        5    0.5
        10   1.5
        15   3.5
        20   6.5
        25   9.5
        30   12.0
        35   13.5
        40   14.0
        45   13.5
        50   12.5
        55   11.5
        60   11.0
        65   11.2
        70   12.0
    ];

        clearRoadPolyline(map, roadCenters, roadWidth, xOffset, yOffset);

    case 3
        % Scenario 3: multi-street layout

        % Horizontal street 1: y = 0
        clearRoadRectangle(map, ...
            0 + xOffset, ...
            -roadWidth/2 + yOffset, ...
            80 + xOffset, ...
            roadWidth/2 + yOffset);

        % Horizontal street 2: y = 25
        clearRoadRectangle(map, ...
            0 + xOffset, ...
            25 - roadWidth/2 + yOffset, ...
            80 + xOffset, ...
            25 + roadWidth/2 + yOffset);

        % Vertical avenue 1: x = 20
        clearRoadRectangle(map, ...
            20 - roadWidth/2 + xOffset, ...
            -20 + yOffset, ...
            20 + roadWidth/2 + xOffset, ...
            45 + yOffset);

        % Vertical avenue 2: x = 55
        clearRoadRectangle(map, ...
            55 - roadWidth/2 + xOffset, ...
            -20 + yOffset, ...
            55 + roadWidth/2 + xOffset, ...
            45 + yOffset);

    otherwise
        error('Invalid scenarioID. Use 1, 2, or 3.');
end

%% Convert Start and Goal to Occupancy Map Coordinates

start = [
    startDriving(1) + xOffset, ...
    startDriving(2) + yOffset, ...
    startDriving(3)
];

goal = [
    goalDriving(1) + xOffset, ...
    goalDriving(2) + yOffset, ...
    goalDriving(3)
];

%% Add Obstacle Vehicles to Occupancy Map

for i = 1:size(obstacleVehicles, 1)

    obsX = obstacleVehicles(i, 1) + xOffset;
    obsY = obstacleVehicles(i, 2) + yOffset;
    obsYaw = deg2rad(obstacleVehicles(i, 3));

    addRotatedObstacle(map, obsX, obsY, obsLength, obsWidth, obsYaw);
end

%% Inflate Obstacles for Vehicle Clearance

vehicleClearance = 0.5;
inflate(map, vehicleClearance);

%% Clear Start and Goal Areas

clearRadius = 1.2;

clearCircle(map, start(1), start(2), clearRadius);
clearCircle(map, goal(1), goal(2), clearRadius);

%% Display Occupancy Map

figure;
show(map);
hold on;

plot(start(1), start(2), 'go', ...
    'MarkerSize', 10, ...
    'LineWidth', 2);

plot(goal(1), goal(2), 'rx', ...
    'MarkerSize', 10, ...
    'LineWidth', 2);

title(['Occupancy Map for ', scenarioName]);
xlabel('X Position on Occupancy Map [m]');
ylabel('Y Position on Occupancy Map [m]');
legend('Start', 'Goal');
grid on;
axis equal;


%%========================================================================= 
% Section 3: A* Path planning
%==========================================================================
% This section runs the A* path planning algorithm on the occupancy map
% created in section 2. A* is a grid-based search algorithm. This means
% that the start and goal position must first be converted from world
% coordinates into grid coordinates. Then, the planner searches for the
% shortest collision free path through the free cells of the occupancy map

% The computation time will be measured using tico/toc so it can be later
% compared against the RRT* algorithm. Once valid point is found, the path
% will be converted back from grid coordinates into world coordinates for
% plotting and metric calculations

fprintf('Running A* planner...\n');

astarTimer = tic;

% Create A* planner using the occupancy map
astarPlanner = plannerAStarGrid(map);

% Convert start and goal from world coordinates to grid coordinates
startGrid = world2grid(map, start(1:2));
goalGrid  = world2grid(map, goal(1:2));

% Run A* path planner
[pathGrid, astarInfo] = plan(astarPlanner, startGrid, goalGrid);

% Stop timer
astarTime = toc(astarTimer);

% Check whether A* found a valid path
if ~isempty(pathGrid)

    % Convert grid path back to world coordinates
    astarPathXY = grid2world(map, pathGrid);

    astarSuccess = true;

    fprintf('A* successfully found a path.\n');
    fprintf('A* computation time: %.4f seconds\n\n', astarTime);

else

    astarPathXY = [];
    astarSuccess = false;

    fprintf('A* failed to find a valid path.\n');
    fprintf('A* computation time: %.4f seconds\n\n', astarTime);

end
%%=========================================================================
% Section 4: RRT* path planning
%==========================================================================

% This section rungs the RRT* path planning algorithm on the same occupancy
% map as A*. RRT* is a sampling-based planner that randomly explores the
% environment by building a tree of possible vehicle states. In comparison
% to A* which searches a grid, RRT* plans in a continous state space
% using the vehicle state [x,y,theta].

% The planner uses the occupancy map to check whetere each sampled state
% and connection is collision free. computation time is also measured so it
% can be compared to against A*. since RRT* is random, there's a
% possibility for production of different paths each time the script is
% run.
fprintf('Running RRT* planner...\n');

rrtTimer = tic;

% Define state space for vehicle motion: [x y theta]
ss = stateSpaceSE2;

% Set bounds based on the occupancy map size from Section 3
ss.StateBounds = [
    0, mapLength
    0, mapWidth
    -pi, pi
];

% Create collision validator using the occupancy map
sv = validatorOccupancyMap(ss);
sv.Map = map;
sv.ValidationDistance = 0.1;

% Create RRT* planner
rrtPlanner = plannerRRTStar(ss, sv);

% RRT* tuning parameters
rrtPlanner.MaxIterations = 6000;
rrtPlanner.MaxConnectionDistance = 3.0;
rrtPlanner.MaxNumTreeNodes = 8000;

% Allow RRT* to keep improving the path after the first solution is found
rrtPlanner.ContinueAfterGoalReached = true;

% Goal is reached when the planner gets close enough to the goal position
rrtPlanner.GoalReachedFcn = @(planner, currentState, goalState) ...
    norm(currentState(1:2) - goalState(1:2)) < 1.0;

% Run RRT* planner
[rrtPathObj, rrtInfo] = plan(rrtPlanner, start, goal);

% Stop timer
rrtTime = toc(rrtTimer);

% Check whether RRT* found a valid path
if rrtInfo.IsPathFound

    rrtPath = rrtPathObj.States;
    rrtPathXY = rrtPath(:,1:2);

    rrtSuccess = true;

    fprintf('RRT* successfully found a path.\n');
    fprintf('RRT* computation time: %.4f seconds\n\n', rrtTime);

else

    rrtPathXY = [];
    rrtSuccess = false;

    fprintf('RRT* failed to find a valid path.\n');
    fprintf('RRT* computation time: %.4f seconds\n\n', rrtTime);

end

