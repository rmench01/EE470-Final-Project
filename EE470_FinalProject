% Helper functions for Section 2


function clearRoadRectangle(map, xMin, yMin, xMax, yMax)

    [X, Y] = meshgrid(xMin:0.05:xMax, yMin:0.05:yMax);
    points = [X(:), Y(:)];

    validIdx = points(:,1) >= 0 & points(:,1) <= map.XWorldLimits(2) & ...
               points(:,2) >= 0 & points(:,2) <= map.YWorldLimits(2);

    points = points(validIdx, :);

    if ~isempty(points)
        setOccupancy(map, points, 0);
    end
end

function clearRoadPolyline(map, roadCenters, roadWidth, xOffset, yOffset)

    roadSampleStep = 0.15;
    widthSampleStep = 0.15;

    for i = 1:size(roadCenters,1)-1

        p1 = roadCenters(i,:);
        p2 = roadCenters(i+1,:);

        segmentVector = p2 - p1;
        segmentLength = norm(segmentVector);

        if segmentLength == 0
            continue;
        end

        direction = segmentVector / segmentLength;
        normal = [-direction(2), direction(1)];

        sValues = 0:roadSampleStep:segmentLength;
        wValues = -roadWidth/2:widthSampleStep:roadWidth/2;

        freePoints = [];

        for s = sValues
            centerPoint = p1 + s * direction;

            for w = wValues
                roadPointDriving = centerPoint + w * normal;

                roadPointMap = [
                    roadPointDriving(1) + xOffset, ...
                    roadPointDriving(2) + yOffset
                ];

                freePoints = [freePoints; roadPointMap];
            end
        end

        validIdx = freePoints(:,1) >= 0 & freePoints(:,1) <= map.XWorldLimits(2) & ...
                   freePoints(:,2) >= 0 & freePoints(:,2) <= map.YWorldLimits(2);

        freePoints = freePoints(validIdx, :);

        if ~isempty(freePoints)
            setOccupancy(map, freePoints, 0);
        end
    end
end

function addRotatedObstacle(map, obsX, obsY, obsLength, obsWidth, obsYaw)

    xLocal = -obsLength/2:0.05:obsLength/2;
    yLocal = -obsWidth/2:0.05:obsWidth/2;

    [Xlocal, Ylocal] = meshgrid(xLocal, yLocal);
    localPoints = [Xlocal(:), Ylocal(:)];

    R = [
        cos(obsYaw), -sin(obsYaw)
        sin(obsYaw),  cos(obsYaw)
    ];

    rotatedPoints = localPoints * R';

    obstaclePoints = rotatedPoints + [obsX, obsY];

    validIdx = obstaclePoints(:,1) >= 0 & obstaclePoints(:,1) <= map.XWorldLimits(2) & ...
               obstaclePoints(:,2) >= 0 & obstaclePoints(:,2) <= map.YWorldLimits(2);

    obstaclePoints = obstaclePoints(validIdx, :);

    if ~isempty(obstaclePoints)
        setOccupancy(map, obstaclePoints, 1);
    end
end

function clearCircle(map, xCenter, yCenter, radius)

    [X, Y] = meshgrid( ...
        xCenter-radius:0.05:xCenter+radius, ...
        yCenter-radius:0.05:yCenter+radius);

    points = [X(:), Y(:)];

    distances = sqrt((points(:,1)-xCenter).^2 + (points(:,2)-yCenter).^2);
    points = points(distances <= radius, :);

    validIdx = points(:,1) >= 0 & points(:,1) <= map.XWorldLimits(2) & ...
               points(:,2) >= 0 & points(:,2) <= map.YWorldLimits(2);

    points = points(validIdx, :);

    if ~isempty(points)
        setOccupancy(map, points, 0);
    end
end

%Helper functions for section 5
function pathLength = computePathLength(path)
    if isempty(path) || size(path,1) < 2
        pathLength = NaN;
        return;
    end

    diffs = diff(path(:,1:2));
    segmentLengths = sqrt(sum(diffs.^2, 2));
    pathLength = sum(segmentLengths);
end

function smoothness = computeSmoothness(path)
    if isempty(path) || size(path,1) < 3
        smoothness = NaN;
        return;
    end

    smoothness = 0;

    for i = 2:size(path,1)-1
        v1 = path(i,:) - path(i-1,:);
        v2 = path(i+1,:) - path(i,:);

        if norm(v1) == 0 || norm(v2) == 0
            continue;
        end

        cosTheta = dot(v1, v2) / (norm(v1) * norm(v2));
        cosTheta = max(min(cosTheta, 1), -1);

        angle = acos(cosTheta);
        smoothness = smoothness + abs(angle);
    end
end

function collisionFree = checkCollisionFree(path, map)
    if isempty(path)
        collisionFree = false;
        return;
    end

    occ = getOccupancy(map, path(:,1:2));
    collisionFree = all(occ < 0.5);
end
