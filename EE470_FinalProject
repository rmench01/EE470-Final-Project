%%=========================================================================
% Section 1: Create automated driving scenario
%This section creates the simulated driving environment using the Automated
%Driving Toolbox. drivingScenario object is used to define the road layout,
%lane structure, ego vehicle and static obstacles vehicles. For this
%project, the ego vehicle represents the autonomous vehicle that must plan
%a collision-free path from the start node into the goal node. 

%The road we are modeling is a straight two-lane road, and several stopped
%vehicles are placed along the road to act as obstacles. These obstaceles
%force the path planning algorithms to generate routes that avoid these
%collision while still staying within the drivable road area. 

%This section provides the autonomous driving context for the project.
%Later sections will convert the scenario into an occupancy map
% were we can implement the A* and RRT* planners 
% 3 scenarios will be tested: Straight road with obstacles, 
%                             curved road with obstacles,
%                             and a city/intersection road layout with
%                             multiple streets.
%choose scenario 
% 1= straight road 
% 2 = curved road 
% 3 = multi-street intersection 

scenarioID = 3;

% creating driving scenario object 
scenario = drivingScenario('SampleTime',0.1,'StopTime',10);

%%default vehicle dimensions

egoLength = 4.7;
egoWidth  = 1.8;

obsLength = 4.7;
obsWidth =  2.0;

% defining each scenario setup
switch scenarioID

    case 1 
        % Scenario 1: straight road with obstacles
        scenarioName ='Scenario 1: Straight Road';

        %defining map limits for occupancy map
        mapXLimits = [0 60];
        mapYLimits = [-8 8];

        %start and end goal in driving scenario coordinates 
        startDriving = [5 -3 0];
        goalDriving = [55 3 0];

        %creating straight two-lane road
        roadCenters = [0 0 0
                       60 0 0
                       ];
        road(scenario, roadCenters, ...
            'Lanes', lanespec(2),...
            'Name', 'Straight Road');

        %obstacle vehicles 
        %format [x y yaw ]

        obstacleVehicles = [ 20 -3 0
                             32 3  0
                             45 -2 0
                             ];
    case 2
        %scenario 2: curved road 

        scenarioName = 'Scenario 2: Curved Road';

         % Map limits used for occupancy map
        mapXLimits = [0 75];
        mapYLimits = [-15 25];

        % Start and goal in driving scenario coordinates
        startDriving = [5 -2 0];
        goalDriving  = [70 12 0];

        % Create curved road using multiple center points
         roadCenters = [
        0    0
        5    0.5
        10   1.5
        15   3.5
        20   6.5
        25   9.5
        30   12.0
        35   13.5
        40   14.0
        45   13.5
        50   12.5
        55   11.5
        60   11.0
        65   11.2
        70   12.0
    ];

        road(scenario, roadCenters, ...
            'Lanes', lanespec(2), ...
            'Name', 'Curved Road');

        % Obstacle vehicles
        % Format: [x y yaw]
        obstacleVehicles = [
    12   2.0    15
    32   12.5   20
    55   11.5   -5
    ];
        
    case 3 
        %scenario 3: multi-street intersection

        scenarioName = 'Scenario 3: Multi-Street Intersection';
        % Map limits for the occupancy map
        mapXLimits = [0 80];
        mapYLimits = [-20 45];

        % Start and goal in driving scenario coordinates
        startDriving = [5 0 0];
        goalDriving  = [75 25 0];

        % Create horizontal streets
        road(scenario, [0 0 0; 80 0 0], ...
            'Lanes', lanespec(2), ...
            'Name', 'Street 1');

        road(scenario, [0 25 0; 80 25 0], ...
            'Lanes', lanespec(2), ...
            'Name', 'Street 2');

        % Create vertical streets
        road(scenario, [20 -20 0; 20 45 0], ...
            'Lanes', lanespec(2), ...
            'Name', 'Avenue 1');

        road(scenario, [55 -20 0; 55 45 0], ...
            'Lanes', lanespec(2), ...
            'Name', 'Avenue 2');

        % Obstacle vehicles
        % Format: [x y yaw]
        obstacleVehicles = [
            30   0    0
            55   10   90
            45   25   0
            20   30   90
        ];

    otherwise
        error('Invalid scenarioID. Use 1, 2, or 3.');
end

% add ego vehicle

ego = vehicle(scenario, ...
    'ClassID', 1, ...
    'Position', startDriving, ...
    'Length', egoLength, ...
    'Width', egoWidth, ...
    'Height', 1.4, ...
    'Name', 'Ego Vehicle');

%add obstacle vehicles 
for i = 1:size(obstacleVehicles, 1)

    obsX = obstacleVehicles(i, 1);
    obsY = obstacleVehicles(i, 2);
    obsYaw = obstacleVehicles(i, 3);

    vehicle(scenario, ...
        'ClassID', 1, ...
        'Position', [obsX obsY 0], ...
        'Yaw', obsYaw, ...
        'Length', obsLength, ...
        'Width', obsWidth, ...
        'Height', 1.5, ...
        'Name', sprintf('Obstacle %d', i));
end

